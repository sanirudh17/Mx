{
  "name": "mx-app",
  "version": "0.4.8",
  "description": "Windows desktop workspace multiplexer for coding workflows",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "compile": "electron-vite build",
    "preview": "electron-vite preview",
    "build": "npm run compile && electron-builder",
    "dist": "npm run compile && electron-builder --win",
    "pack": "npm run compile && electron-builder --dir"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^5.5.0",
    "allotment": "^1.20.5",
    "chokidar": "^5.0.0",
    "cmdk": "^1.1.1",
    "electron-log": "^5.3.3",
    "electron-store": "^11.0.0",
    "geist": "^1.7.0",
    "lucide-react": "^0.577.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^11.1.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  },
  "build": {
    "appId": "com.mx.app",
    "productName": "Mx",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "uninstallDisplayName": "Mx"
    },
    "asar": true,
    "publish": null
  }
}
